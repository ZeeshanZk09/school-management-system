generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
  PENDING_APPROVAL
}

enum SessionRevokeReason {
  USER_LOGOUT
  ADMIN_REVOKED
  PASSWORD_CHANGED
  ROLE_CHANGED
  ACCOUNT_DEACTIVATED
  COMPROMISED
}

enum TokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
  CSRF
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

enum StudentStatus {
  ACTIVE
  PASSED_OUT
  WITHDRAWN
}

enum EmploymentType {
  PERMANENT
  CONTRACT
  PART_TIME
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum StaffAttendanceStatus {
  PRESENT
  ABSENT
  ON_LEAVE
  HALF_DAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum FeeFrequency {
  MONTHLY
  SEMESTER
  YEARLY
  ONE_TIME
}

enum FeeRecordStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum SalaryComponentType {
  ALLOWANCE
  DEDUCTION
}

enum GuardianRelation {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuthEventType {
  LOGIN
  LOGOUT
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  fullName         String
  passwordHash     String
  status           UserStatus @default(ACTIVE)
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  isDeleted        Boolean    @default(false) @map("is_deleted")
  approvedBy       User?      @relation("UserApproval", fields: [approvedByUserId], references: [id])
  approvedByUserId String?
  approvalsGiven   User[]     @relation("UserApproval")

  roles                      UserRole[]
  rolesAssigned              UserRole[]           @relation("UserRoleAssignedBy")
  sessions                   Session[]
  authEvents                 AuthEvent[]
  staff                      Staff?
  createdAnnouncements       Announcement[]       @relation("AnnouncementCreator")
  auditEntries               AuditLog[]           @relation("AuditActor")
  recordedStudentAttendance  StudentAttendance[]  @relation("StudentAttendanceRecordedBy")
  correctedStudentAttendance StudentAttendance[]  @relation("StudentAttendanceCorrectedBy")
  recordedStaffAttendance    StaffAttendance[]    @relation("StaffAttendanceRecordedBy")
  decidedLeaveRequests       LeaveRequest[]       @relation("LeaveRequestDecidedBy")
  feePayments                FeePayment[]         @relation("FeePaymentReceivedBy")
  salaryDisbursements        SalaryDisbursement[] @relation("SalaryDisbursementPaidBy")
  uploadedStaffDocuments     StaffDocument[]      @relation("StaffDocumentUploadedBy")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  isDeleted  Boolean    @default(false) @map("is_deleted")

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId       String
  roleId       String
  assignedById String?
  assignedAt   DateTime @default(now())

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy User?   @relation("UserRoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  isDeleted  Boolean @default(false) @map("is_deleted")

  @@id([userId, roleId])
  @@index([roleId])
  @@index([assignedById])
}

model Session {
  id            String               @id @default(cuid())
  userId        String
  tokenHash     String               @unique
  expiresAt     DateTime
  ipAddress     String?
  userAgent     String?
  lastSeenAt    DateTime?
  revokedAt     DateTime?
  revokedReason SessionRevokeReason?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted Boolean @default(false) @map("is_deleted")

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model OneTimeToken {
  id          String    @id @default(cuid())
  identifier  String
  tokenHash   String    @unique
  type        TokenType
  expiresAt   DateTime
  consumedAt  DateTime?
  requestedIp String?
  createdAt   DateTime  @default(now())
  isDeleted   Boolean   @default(false) @map("is_deleted")

  @@index([identifier, type])
}

model AuthEvent {
  id         String        @id @default(cuid())
  userId     String?
  eventType  AuthEventType
  ipAddress  String?
  userAgent  String?
  occurredAt DateTime      @default(now())

  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  isDeleted Boolean @default(false) @map("is_deleted")

  @@index([userId, occurredAt])
}

model AcademicYear {
  id        String   @id @default(cuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false) @map("is_deleted")

  enrollments             StudentEnrollment[]
  feeStructures           FeeStructure[]
  leaveBalances           LeaveBalance[]
  leaveRequests           LeaveRequest[]
  classTeacherAssignments ClassTeacherAssignment[]
  studentAttendance       StudentAttendance[]
  academicCalendarEvents  AcademicCalendarEvent[]
  feeRecord               FeeRecord[]
}

model Class {
  id        String   @id @default(cuid())
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false) @map("is_deleted")

  sections                Section[]
  enrollments             StudentEnrollment[]
  feeStructures           FeeStructure[]
  classTeacherAssignments ClassTeacherAssignment[]
  studentAttendance       StudentAttendance[]
  feeRecord               FeeRecord[]

  @@unique([name])
}

model Section {
  id             String   @id @default(cuid())
  classId        String
  name           String
  classTeacherId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  capacity       Int?     @default(30)
  isDeleted      Boolean  @default(false) @map("is_deleted")

  class                  Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classTeacher           Staff?                   @relation(fields: [classTeacherId], references: [id], onDelete: SetNull)
  enrollments            StudentEnrollment[]
  studentAttendance      StudentAttendance[]
  classTeacherAssignment ClassTeacherAssignment[]

  @@unique([classId, name])
  @@index([classTeacherId])
}

model Staff {
  id                           String         @id @default(cuid())
  userId                       String         @unique
  fullName                     String
  dateOfBirth                  DateTime?
  gender                       Gender         @default(UNSPECIFIED)
  photoUrl                     String?
  designation                  String
  department                   String
  joiningDate                  DateTime
  employmentType               EmploymentType
  qualification                String?
  cnic                         String?
  email                        String?
  personalPhone                String?
  workPhone                    String?
  address                      String?
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  staffNumber                  String         @unique
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  isDeleted                    Boolean        @default(false) @map("is_deleted")

  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents               StaffDocument[]
  attendance              StaffAttendance[]
  leaveBalances           LeaveBalance[]
  leaveRequests           LeaveRequest[]
  salaryStructures        SalaryStructure[]
  salarySlips             SalarySlip[]
  classTeacherAssignments ClassTeacherAssignment[]
  sections                Section[]

  @@index([department])
  @@index([designation])
  @@index([employmentType])
  @@index([joiningDate])
}

model StaffDocument {
  id           String   @id @default(cuid())
  staffId      String
  title        String
  fileName     String
  filePath     String
  mimeType     String
  sizeBytes    Int
  uploadedById String?
  uploadedAt   DateTime @default(now())
  isDeleted    Boolean  @default(false) @map("is_deleted")

  staff      Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("StaffDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([staffId])
}

model Student {
  id              String        @id @default(cuid())
  fullName        String
  dateOfBirth     DateTime?
  gender          Gender        @default(UNSPECIFIED)
  bloodGroup      String?
  photoUrl        String?
  admissionDate   DateTime
  status          StudentStatus @default(ACTIVE)
  admissionNumber String        @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  isDeleted       Boolean       @default(false) @map("is_deleted")

  enrollments StudentEnrollment[]
  guardians   StudentGuardian[]
  siblings    StudentSibling[]
  attendance  StudentAttendance[]
  feeRecords  FeeRecord[]

  @@index([fullName])
  @@index([status])
}

model StudentEnrollment {
  id             String   @id @default(cuid())
  studentId      String
  academicYearId String
  classId        String
  sectionId      String?
  rollNumber     String
  enrollmentDate DateTime @default(now())
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false) @map("is_deleted")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Restrict)
  section      Section?     @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@unique([studentId, academicYearId])
  @@index([classId, sectionId, academicYearId])
  @@index([rollNumber])
}

model Guardian {
  id             String   @id @default(cuid())
  fullName       String
  primaryPhone   String
  secondaryPhone String?
  email          String?
  address        String?
  occupation     String?
  nationalId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false) @map("is_deleted")

  students StudentGuardian[]
}

model StudentGuardian {
  studentId          String
  guardianId         String
  relationship       GuardianRelation
  isPrimaryEmergency Boolean          @default(false)

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian  Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  isDeleted Boolean  @default(false) @map("is_deleted")

  @@id([studentId, guardianId])
  @@index([guardianId])
}

model SiblingGroup {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false) @map("is_deleted")

  members StudentSibling[]
}

model StudentSibling {
  siblingGroupId String
  studentId      String

  group     SiblingGroup @relation(fields: [siblingGroupId], references: [id], onDelete: Cascade)
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  isDeleted Boolean      @default(false) @map("is_deleted")

  @@id([siblingGroupId, studentId])
}

model ClassTeacherAssignment {
  id             String   @id @default(cuid())
  staffId        String
  classId        String
  sectionId      String?
  academicYearId String
  assignedAt     DateTime @default(now())
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false) @map("is_deleted")

  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?     @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([staffId, classId, sectionId, academicYearId])
  @@index([classId, academicYearId])
}

model AttendanceSession {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  startTime String?
  endTime   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false) @map("is_deleted")

  studentAttendance StudentAttendance[]
}

model StudentAttendance {
  id                String           @id @default(cuid())
  studentId         String
  classId           String
  sectionId         String?
  academicYearId    String
  sessionId         String
  attendanceDate    DateTime
  status            AttendanceStatus
  note              String?
  recordedByUserId  String
  recordedAt        DateTime         @default(now())
  correctionReason  String?
  correctedByUserId String?
  correctedAt       DateTime?
  isDeleted         Boolean          @default(false) @map("is_deleted")

  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class        Class             @relation(fields: [classId], references: [id], onDelete: Restrict)
  section      Section?          @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  academicYear AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  session      AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  recordedBy   User              @relation("StudentAttendanceRecordedBy", fields: [recordedByUserId], references: [id], onDelete: Restrict)
  correctedBy  User?             @relation("StudentAttendanceCorrectedBy", fields: [correctedByUserId], references: [id], onDelete: SetNull)

  @@unique([studentId, classId, attendanceDate, sessionId])
  @@index([classId, attendanceDate])
  @@index([studentId, attendanceDate])
  @@index([academicYearId])
}

model StaffAttendance {
  id               String                @id @default(cuid())
  staffId          String
  attendanceDate   DateTime
  status           StaffAttendanceStatus
  note             String?
  recordedByUserId String
  recordedAt       DateTime              @default(now())
  isDeleted        Boolean               @default(false) @map("is_deleted")

  staff      Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  recordedBy User  @relation("StaffAttendanceRecordedBy", fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@unique([staffId, attendanceDate])
  @@index([attendanceDate])
}

model LeaveType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false) @map("is_deleted")

  balances LeaveBalance[]
  requests LeaveRequest[]
}

model LeaveBalance {
  id             String   @id @default(cuid())
  staffId        String
  academicYearId String
  leaveTypeId    String
  totalDays      Float
  usedDays       Float    @default(0)
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false) @map("is_deleted")

  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  leaveType    LeaveType    @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@unique([staffId, academicYearId, leaveTypeId])
}

model LeaveRequest {
  id              String      @id @default(cuid())
  staffId         String
  academicYearId  String
  leaveTypeId     String
  startDate       DateTime
  endDate         DateTime
  reason          String?
  status          LeaveStatus @default(PENDING)
  appliedAt       DateTime    @default(now())
  decidedAt       DateTime?
  decidedByUserId String?
  decisionNote    String?
  isDeleted       Boolean     @default(false) @map("is_deleted")

  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  leaveType    LeaveType    @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  decidedBy    User?        @relation("LeaveRequestDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([staffId, status])
  @@index([academicYearId])
}

model FeeStructure {
  id             String   @id @default(cuid())
  classId        String
  academicYearId String
  name           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false) @map("is_deleted")

  class        Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  components   FeeComponent[]
  feeRecords   FeeRecord[]

  @@index([classId, academicYearId])
}

model FeeComponent {
  id             String       @id @default(cuid())
  feeStructureId String
  label          String
  amount         Decimal      @db.Decimal(10, 2)
  dueDate        DateTime
  frequency      FeeFrequency
  sortOrder      Int          @default(0)
  isDeleted      Boolean      @default(false) @map("is_deleted")

  feeStructure   FeeStructure    @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  feeRecordItems FeeRecordItem[]

  @@index([feeStructureId])
}

model FeeRecord {
  id                String          @id @default(cuid())
  studentId         String
  classId           String
  academicYearId    String
  feeStructureId    String
  discountAmount    Decimal         @default(0) @db.Decimal(10, 2)
  waiverAmount      Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount       Decimal         @db.Decimal(10, 2)
  outstandingAmount Decimal         @db.Decimal(10, 2)
  status            FeeRecordStatus @default(OPEN)
  dueDate           DateTime
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  isDeleted         Boolean         @default(false) @map("is_deleted")

  student      Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class        Class           @relation(fields: [classId], references: [id], onDelete: Restrict)
  academicYear AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  feeStructure FeeStructure    @relation(fields: [feeStructureId], references: [id], onDelete: Restrict)
  items        FeeRecordItem[]
  payments     FeePayment[]

  @@index([studentId, academicYearId])
}

model FeeRecordItem {
  id             String   @id @default(cuid())
  feeRecordId    String
  feeComponentId String?
  label          String
  amount         Decimal  @db.Decimal(10, 2)
  dueDate        DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false) @map("is_deleted")

  feeRecord    FeeRecord     @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)
  feeComponent FeeComponent? @relation(fields: [feeComponentId], references: [id], onDelete: SetNull)

  @@index([feeRecordId])
}

model FeePayment {
  id               String        @id @default(cuid())
  feeRecordId      String
  amountPaid       Decimal       @db.Decimal(10, 2)
  paidAt           DateTime
  method           PaymentMethod
  referenceNumber  String?
  receivedByUserId String
  note             String?
  createdAt        DateTime      @default(now())
  isDeleted        Boolean       @default(false) @map("is_deleted")

  feeRecord  FeeRecord   @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)
  receivedBy User        @relation("FeePaymentReceivedBy", fields: [receivedByUserId], references: [id], onDelete: Restrict)
  receipt    FeeReceipt?

  @@index([feeRecordId, paidAt])
}

model FeeReceipt {
  id        Int      @id @default(autoincrement())
  paymentId String   @unique
  issuedAt  DateTime @default(now())

  payment   FeePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  isDeleted Boolean    @default(false) @map("is_deleted")
}

model SalaryStructure {
  id        String   @id @default(cuid())
  staffId   String
  basePay   Decimal  @db.Decimal(10, 2)
  validFrom DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false) @map("is_deleted")

  staff       Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  components  SalaryComponent[]
  salarySlips SalarySlip[]

  @@index([staffId, validFrom])
}

model SalaryComponent {
  id                String              @id @default(cuid())
  salaryStructureId String
  type              SalaryComponentType
  label             String
  amount            Decimal             @db.Decimal(10, 2)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  isDeleted         Boolean             @default(false) @map("is_deleted")

  salaryStructure SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)
}

model SalarySlip {
  id                String   @id @default(cuid())
  staffId           String
  salaryStructureId String
  periodYear        Int
  periodMonth       Int
  grossPay          Decimal  @db.Decimal(10, 2)
  totalDeductions   Decimal  @db.Decimal(10, 2)
  netPay            Decimal  @db.Decimal(10, 2)
  generatedAt       DateTime @default(now())
  isDeleted         Boolean  @default(false) @map("is_deleted")

  staff           Staff                @relation(fields: [staffId], references: [id], onDelete: Cascade)
  salaryStructure SalaryStructure      @relation(fields: [salaryStructureId], references: [id], onDelete: Restrict)
  disbursements   SalaryDisbursement[]

  @@unique([staffId, periodYear, periodMonth])
  @@index([periodYear, periodMonth])
}

model SalaryDisbursement {
  id              String        @id @default(cuid())
  salarySlipId    String
  amountPaid      Decimal       @db.Decimal(10, 2)
  paidAt          DateTime
  method          PaymentMethod
  referenceNumber String?
  paidByUserId    String?
  createdAt       DateTime      @default(now())
  isDeleted       Boolean       @default(false) @map("is_deleted")

  salarySlip SalarySlip @relation(fields: [salarySlipId], references: [id], onDelete: Cascade)
  paidBy     User?      @relation("SalaryDisbursementPaidBy", fields: [paidByUserId], references: [id], onDelete: SetNull)

  @@index([paidAt])
}

model Announcement {
  id              String    @id @default(cuid())
  title           String
  body            String
  publishedAt     DateTime  @default(now())
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isDeleted       Boolean   @default(false) @map("is_deleted")

  createdBy User @relation("AnnouncementCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([publishedAt])
}

model SystemSettings {
  id                    Int      @id @default(autoincrement())
  schoolName            String
  schoolLogoUrl         String?
  addressLine1          String
  addressLine2          String?
  city                  String?
  state                 String?
  country               String?
  postalCode            String?
  contactEmail          String?
  contactPhone          String?
  allowSelfRegistration Boolean  @default(false)
  attendanceSessions    Json     @default("[\"Morning\", \"Afternoon\"]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AcademicCalendarEvent {
  id             String   @id @default(cuid())
  academicYearId String?
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false) @map("is_deleted")

  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)

  @@index([academicYearId])
}

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String?
  action      AuditAction
  tableName   String
  recordId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  note        String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

